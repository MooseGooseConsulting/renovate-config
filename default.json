{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "MooseGoose shared Renovate preset: agent-review-first, low-noise dependency updates.",
  "extends": [
    "config:best-practices"
  ],
  "timezone": "America/Chicago",
  "dependencyDashboard": false,
  "addLabels": [
    "dependencies",
    "agent-review"
  ],
  "prHeader": "Agent review expected: verify the dependency impact, summarize CI status, and merge only when the update is coherent for this repo.",
  "reviewers": [
    "Coldaine"
  ],
  "reviewersFromCodeOwners": true,
  "assignees": [
    "Coldaine"
  ],
  "prConcurrentLimit": 2,
  "branchConcurrentLimit": 2,
  "prHourlyLimit": 1,
  "prCreation": "not-pending",
  "internalChecksFilter": "strict",
  "schedule": [
    "* 4-8 * * 1-5"
  ],
  "updateNotScheduled": false,
  "rebaseWhen": "conflicted",
  "automerge": false,
  "packageRules": [
    {
      "description": "Label major updates for agent triage.",
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major-upgrade"
      ]
    },
    {
      "description": "Group npm production dependency minor and patch updates.",
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "dependencies"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "npm production dependencies"
    },
    {
      "description": "Group npm development dependency minor and patch updates.",
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "npm development dependencies"
    },
    {
      "description": "Group GitHub Actions minor and patch updates.",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github actions"
    },
    {
      "description": "Group Dockerfile minor and patch updates.",
      "matchManagers": [
        "dockerfile"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "docker images"
    },
    {
      "description": "Group devcontainer minor and patch updates.",
      "matchManagers": [
        "devcontainer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "devcontainer images and features"
    }
  ],
  "vulnerabilityAlerts": {
    "addLabels": [
      "security",
      "dependencies",
      "agent-review"
    ],
    "schedule": [],
    "minimumReleaseAge": null,
    "prCreation": "immediate"
  }
}
